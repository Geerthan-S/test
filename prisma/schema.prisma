generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
}

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  COMPLETED
  ON_HOLD
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         Role      @default(EDITOR)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  projects     Project[] @relation("ProjectAuthor")

  @@index([role])
}

model Project {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  clientName      String
  clientType      String?
  clientLogo      String?
  featuredImage   String
  gallery         String[]      @default([])
  location        String
  scopeOfWork     String
  timeline        String
  projectValue    String
  yearsAssociated String?
  projectCount    String?
  contractValue   String?
  status          ProjectStatus @default(IN_PROGRESS)
  servicesUsed    String[]      @default([])
  industry        String
  summary         String
  clientOverview  String?
  keyAchievements String[]      @default([])
  body            String
  seoTitle        String?
  seoDescription  String?
  published       Boolean       @default(true)
  featured        Boolean       @default(false)
  completedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  authorId        String?
  author          User?         @relation("ProjectAuthor", fields: [authorId], references: [id])
  testimonial     Testimonial?

  @@index([published, featured, updatedAt])
  @@index([status, updatedAt])
  @@index([industry])
}

model Testimonial {
  id          String   @id @default(cuid())
  quote       String
  personName  String
  designation String
  company     String
  avatar      String?
  projectId   String?  @unique
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published, updatedAt])
}

model MediaAsset {
  id           String   @id @default(cuid())
  publicId     String
  secureUrl    String
  resourceType String
  alt          String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

model Client {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logoUrl     String?
  industry    String?
  website     String?
  testimonial String?
  featured    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([featured, updatedAt])
  @@index([industry])
}

model SeoEntry {
  id          String   @id @default(cuid())
  path        String   @unique
  title       String
  description String
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SitePage {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  description     String
  heroTitle       String
  heroDescription String
  heroImage       String
  sections        Json
  published       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([published, slug])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([email])
}
