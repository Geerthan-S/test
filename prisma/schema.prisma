generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model CareerSetting {
  id                   String   @id
  internshipButtonText String   @default("Apply for Internship")
  internshipActionType String   @default("modal")
  internshipActionUrl  String   @default("")
  updatedAt            DateTime
}

model Client {
  id          String   @id
  name        String
  slug        String   @unique
  logoUrl     String?
  industry    String?
  website     String?
  testimonial String?
  featured    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  @@index([featured, updatedAt])
  @@index([industry])
}

model ContactMessage {
  id                     String   @id
  name                   String
  email                  String
  phone                  String?
  company                String?
  inquiryType            String   @default("General")
  grievanceCategory      String?
  projectLocation        String?
  priorityLevel          String?
  preferredContactMethod String?
  message                String
  attachments            String[] @default([])
  createdAt              DateTime @default(now())

  @@index([createdAt])
  @@index([email])
  @@index([inquiryType])
}

model Download {
  id        String   @id
  title     String
  category  String
  fileUrl   String
  fileType  String   @default("pdf")
  sortOrder Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime

  @@index([published, category])
}

model Equipment {
  id           String   @id
  name         String
  slug         String   @unique
  imageUrl     String?
  quantity     Int      @default(1)
  capacity     String?
  manufacturer String?
  year         Int?
  status       String   @default("Active")
  sortOrder    Int      @default(0)
  published    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime

  @@index([published, sortOrder])
}

model JobOpening {
  id         String   @id
  title      String
  department String
  experience String
  location   String
  type       String   @default("Full-Time")
  skills     String[] @default([])
  published  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime

  @@index([published, updatedAt])
}

model MediaAsset {
  id           String   @id
  publicId     String
  secureUrl    String
  resourceType String
  alt          String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

model Project {
  id                String        @id
  title             String
  slug              String        @unique
  clientName        String
  clientLogo        String?
  featuredImage     String
  gallery           String[]      @default([])
  location          String
  scopeOfWork       String
  timeline          String
  projectValue      String
  status            ProjectStatus @default(IN_PROGRESS)
  servicesUsed      String[]      @default([])
  industry          String
  summary           String
  body              String
  seoTitle          String?
  seoDescription    String?
  published         Boolean       @default(true)
  featured          Boolean       @default(false)
  completedAt       DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime
  authorId          String?
  clientOverview    String?
  clientType        String?
  contractValue     String?
  keyAchievements   String[]      @default([])
  projectCount      String?
  yearsAssociated   String?
  builtUpArea       String?
  completionPct     Int           @default(0)
  concreteUsed      String?
  endDate           DateTime?
  folderName        String?
  roadLength        String?
  startDate         DateTime?
  steelUsed         String?
  workforceDeployed String?
  User              User?         @relation(fields: [authorId], references: [id])
  Testimonial       Testimonial?

  @@index([industry])
  @@index([published, featured, updatedAt])
  @@index([status, updatedAt])
}

model SeoEntry {
  id          String   @id
  path        String   @unique
  title       String
  description String
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime
}

model SitePage {
  id              String   @id
  slug            String   @unique
  title           String
  description     String
  heroTitle       String
  heroDescription String
  heroImage       String
  sections        Json
  published       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime

  @@index([published, slug])
}

model SiteSetting {
  id        String   @id
  key       String   @unique
  value     String
  updatedAt DateTime
}

model Testimonial {
  id          String   @id
  quote       String
  personName  String
  designation String
  company     String
  avatar      String?
  projectId   String?  @unique
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  Project     Project? @relation(fields: [projectId], references: [id])

  @@index([published, updatedAt])
}

model User {
  id           String    @id
  name         String
  email        String    @unique
  passwordHash String
  role         Role      @default(EDITOR)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime
  Project      Project[]

  @@index([role])
}

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  COMPLETED
  ON_HOLD
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
}
